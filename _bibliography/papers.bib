@inproceedings{younis2026splatfusion,
  title        = {SplatFusion: Training-Free {3D} Scene Completion
                  from Sparse Views Using Temporal Diffusion Priors
                  and {Gaussian Splatting}},
  author       = {Younis, Tanveer and Khan, Dawar and Cheng, Zhanglin},
  booktitle    = {International Conference on 3D Vision (3DV)},
  year         = {2026},
  abbr         = {3DV},
  selected     = {true},
  note         = {To appear},
  preview      = {splatfusion.gif},
  abstract     = {Reconstructing complete 3D scenes from extremely sparse
                  viewpoints remains a core yet unsolved challenge. We introduce
                  SplatFusion, a training-free framework that leverages pretrained
                  video diffusion priors with a novel Scene-Consistent Temporal
                  Guidance (SCTG) mechanism to enforce spatial and temporal
                  coherence during reconstruction from only 2–3 wide-baseline images.}
}
